# LLM (optional — agent falls back to rule-based analysis without this)
ANTHROPIC_API_KEY=

# Probe host (Raspberry Pi or other always-on LAN host)
PROBE_HOST=192.168.1.100
PROBE_USER=pi
# Prefer SSH key auth (recommended):
PROBE_SSH_KEY=~/.ssh/id_ed25519
# Password fallback only if key auth unavailable:
PROBE_PASSWORD=

# Ping targets (comma-separated); gateway is auto-detected if omitted
LATENCY_TARGETS=192.168.1.1,1.1.1.1,8.8.8.8

# Use static fake data instead of live probes (for offline dev)
USE_MOCK_PROBES=false

# Safety: actions require explicit confirm when true (default)
DRY_RUN=true
